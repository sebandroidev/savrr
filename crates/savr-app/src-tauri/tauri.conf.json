{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Savr",
  "version": "0.1.2",
  "identifier": "dev.savr.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --dir ../ui dev",
    "beforeBuildCommand": "pnpm --dir ../ui build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Savr",
        "width": 1040,
        "height": 720,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true,
        "center": true
      }
    ],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/32x32.png",
      "tooltip": "Savr"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/savr-daemon"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVCOTk0Q0U0MzMyMkE1N0YKUldSL3BTSXo1RXlaNjRjQnhnZEE2N01McXpPNGRoaHVId3VQcTU3cFNWM09objZ0Smpzam52VGQK",
      "endpoints": [
        "https://github.com/sebandroidev/savrr/releases/latest/download/latest.json"
      ]
    }
  }
}
